# Open Paws Fundraising Intelligence — Environment Variables
# Copy to .env and fill in your values. Never commit .env.

# Open Paws API Gateway
OPEN_PAWS_GATEWAY_URL=https://api.openpaws.ai/v1
OPEN_PAWS_API_KEY=op_fundraising-key-here
LLM_MODEL=claude-haiku-4-5-20251001

# Auth — format: "key1:org_id_1,key2:org_id_2"
FUNDRAISING_API_KEYS=your-key-here:your-org-id-here

# Optional: Database path (default: data/grant_pipeline.db)
# FUNDRAISING_DB_PATH=data/grant_pipeline.db

# Optional: API server settings
# API_HOST=0.0.0.0
# API_PORT=8000
