# Open Paws Fundraising Intelligence — Environment Variables
# Copy to .env and fill in your values. Never commit .env.

# Required: Anthropic API key for LLM-powered drafting and re-engagement
# Zero-retention usage: see https://www.anthropic.com/legal/privacy
# For investigation-adjacent orgs: use a self-hosted model instead (see CLAUDE.md)
ANTHROPIC_API_KEY=your-key-here

# Optional: Database path (default: data/grant_pipeline.db)
# FUNDRAISING_DB_PATH=data/grant_pipeline.db

# Optional: API server settings
# API_HOST=0.0.0.0
# API_PORT=8000
